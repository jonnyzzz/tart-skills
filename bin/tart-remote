#!/usr/bin/env bash
# tart-remote — the Mac-side orchestrator for tart-skills.
#
# Installed on the *Mac host* (Apple Silicon, with Tart). A remote agent
# (typically running Linux) drives it over SSH:
#
#     ssh $MAC_USER@$MAC_HOST 'tart-remote vm-up'
#     ssh $MAC_USER@$MAC_HOST 'tart-remote screenshot -' > shot.png
#
# It owns the *inner* hop (Mac host -> tart VM guest): booting a detached VM
# that survives the SSH session closing, a multiplexed SSH connection into the
# guest (ControlMaster — avoids sshd anti-bruteforce lockouts), and the
# GUI-driving primitives (screencapture, cliclick, IntelliJ) that make GUI
# testing inside the VM possible.
#
# Everything the agent needs to *read* goes to stdout; all human/log output
# goes to stderr, so `... screenshot -` can stream raw PNG bytes cleanly.
set -eo pipefail

# ---- configuration (override via env) --------------------------------------
VM="${TART_VM:-tart-skills-vm}"
IMAGE="${TART_IMAGE:-ghcr.io/cirruslabs/macos-tahoe-base:latest}"
CPU="${TART_CPU:-4}"
MEMORY="${TART_MEMORY:-8192}"            # MiB
DISPLAY_SIZE="${TART_DISPLAY:-1600x900}"
GUEST_USER="${TART_USER:-admin}"
GUEST_PASS="${TART_PASS:-admin}"
# macOS 15+/26 guests need an UNLOCKED login.keychain on the HOST, or Apple's
# Virtualization.framework fails to boot them with a Code=-9 "security error"
# ("Failed to create new HostKey") — a headless SSH session leaves the keychain
# locked. Set TART_KEYCHAIN_PW to the Mac host user's LOGIN password to have
# vm-up unlock it. (Linux guests don't need this.) Leave empty if a GUI login
# session already keeps the keychain unlocked.
KEYCHAIN_PW="${TART_KEYCHAIN_PW:-}"
SHARE="${TART_DIR:-}"                     # optional: name:/host/path[:ro]  or  /host/path:tag=foo
# Shared host cache — one copy of heavy binaries (IntelliJ) on the HOST, mounted
# read-only into every VM. Saves re-downloading per VM and avoids a per-VM copy
# in each guest's disk. Shared across ALL tart-skills VMs on this host.
CACHE_DIR="${TART_CACHE_DIR:-$HOME/tart-skills-cache}"
CACHE_TAG=tartcache
GUEST_CACHE="/Volumes/My Shared Files/$CACHE_TAG"   # mount point inside the guest
STATE_DIR="${TART_STATE_DIR:-$HOME/.tart-remote}"
ART_DIR="$STATE_DIR/artifacts"
MUX="$STATE_DIR/mux-$VM"
RUN_LOG="$STATE_DIR/run-$VM.log"

mkdir -p "$STATE_DIR" "$ART_DIR"

# tart may live in Homebrew or a brew-less install under ~/bin; a non-login ssh
# shell may not have either on PATH.
export PATH="$HOME/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

log() { echo "[tart-remote] $(date -u +%FT%TZ) $*" >&2; }
die() { log "ERROR: $*"; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1 (brew install $2)"; }

vm_ip() { tart ip "$VM" 2>/dev/null || true; }
vm_running() { tart list 2>/dev/null | awk -v v="$VM" '$2==v {print $NF}' | grep -qi running; }
vm_exists() { tart list 2>/dev/null | awk -v v="$VM" '$2==v {found=1} END{exit !found}'; }

# One multiplexed SSH connection into the guest. Rapid separate password
# connections trip macOS sshd's per-source penalty ("Too many authentication
# failures"); ControlMaster rides every ssh/scp over a single channel.
GUEST_SSH_OPTS=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null
  -o LogLevel=ERROR -o PreferredAuthentications=password -o PubkeyAuthentication=no
  -o IdentitiesOnly=yes -o ControlMaster=auto -o ControlPath="$MUX" -o ControlPersist=1800)
# Password auth for the guest. Prefer sshpass if installed; otherwise use
# OpenSSH's SSH_ASKPASS (SSH_ASKPASS_REQUIRE=force works with no tty on
# OpenSSH 8.4+, which ships with modern macOS) — so the ONLY hard dependency on
# the Mac host is `tart` + stock `ssh`, no Homebrew required.
ASKPASS="$STATE_DIR/askpass.sh"
if command -v sshpass >/dev/null 2>&1; then
  AUTH=sshpass
else
  AUTH=askpass
  printf '#!/bin/sh\nprintf %%s %q\n' "$GUEST_PASS" > "$ASKPASS"
  chmod 700 "$ASKPASS"
fi
_ssh() {  # _ssh <ssh|scp> <args...>
  local bin="$1"; shift
  if [ "$AUTH" = sshpass ]; then
    sshpass -p "$GUEST_PASS" "$bin" "$@"
  else
    SSH_ASKPASS="$ASKPASS" SSH_ASKPASS_REQUIRE=force DISPLAY=:0 \
      "$bin" -o NumberOfPasswordPrompts=1 "$@"
  fi
}

# Brew tools (cliclick, ffmpeg) are in /opt/homebrew/bin, which a NON-interactive
# SSH shell does not put on PATH (it sources only ~/.zshenv). Prefix a PATH
# export on every remote *command* so cliclick/ffmpeg/etc. resolve; leave an
# interactive shell (no args) untouched.
GUEST_PATH='export PATH=/opt/homebrew/bin:/usr/local/bin:/usr/sbin:$PATH;'
gssh() {
  local ip; ip="$(vm_ip)"; [ -n "$ip" ] || die "VM '$VM' has no IP — run: tart-remote vm-up"
  if [ "$#" -eq 0 ]; then
    _ssh ssh "${GUEST_SSH_OPTS[@]}" "$GUEST_USER@$ip"
  else
    _ssh ssh "${GUEST_SSH_OPTS[@]}" "$GUEST_USER@$ip" "$GUEST_PATH $*"
  fi
}
gscp() {
  local ip; ip="$(vm_ip)"; [ -n "$ip" ] || die "VM '$VM' has no IP — run: tart-remote vm-up"
  # usage: gscp <local> :<remote>   OR   gscp :<remote> <local>   (: = guest side)
  local a="${1/#:/$GUEST_USER@$ip:}" b="${2/#:/$GUEST_USER@$ip:}"
  _ssh scp "${GUEST_SSH_OPTS[@]}" "$a" "$b"
}

preflight() {
  need tart cirruslabs/cli/tart
  # sshpass is optional — the SSH_ASKPASS fallback covers hosts without it.
}

usage() {
  cat >&2 <<EOF
tart-remote — drive a full-GUI macOS tart VM from a remote agent over SSH.

VM lifecycle (management "service"):
  vm-create            clone \$TART_IMAGE into VM '$VM' (no-op if it exists)
  vm-up                configure + boot detached (survives SSH close) + wait for IP
  vm-ip                print the VM IP
  vm-status            running? ip? provisioned?
  vm-down              stop the VM (keeps the disk)
  vm-gc                delete the VM entirely
  vm-list | ls         list ALL tart VMs on this host (respect ones you didn't create)
  provision            copy + run provision.sh in the guest (IntelliJ, ffmpeg, TCC grant)

Shared host cache (one IDE copy for all VMs — faster, less disk):
  cache-setup          download IntelliJ IDEA CE into \$TART_CACHE_DIR once (on the host)
  cache-status         show what the shared cache holds

Drive the GUI (for GUI testing):
  guest [cmd...]       run a command in the guest (interactive shell if no cmd)
  screenshot [OUT]     capture the screen; OUT path on host, or '-'/omitted = raw PNG to stdout
  record SECS [OUT]    record SECS of screen video; OUT path on host, or '-' = raw mov to stdout
  start-ide [PROJECT]  launch IntelliJ IDEA (open PROJECT dir if given), wait until ready
  click X Y            move+click at guest screen coords (cliclick)
  type TEXT            type TEXT into the focused guest field (cliclick)
  key KEYSTROKE        send a key/combo, e.g. 'cmd+space' (cliclick ku:/kd:)
  pull :REMOTE LOCAL   copy a file out of the guest to the host

Env: TART_VM TART_IMAGE TART_CPU TART_MEMORY TART_DISPLAY TART_USER TART_PASS
     TART_DIR TART_CACHE_DIR TART_KEYCHAIN_PW
Current: VM=$VM IMAGE=$IMAGE CPU=$CPU MEM=${MEMORY}MiB DISPLAY=$DISPLAY_SIZE
         CACHE_DIR=$CACHE_DIR
EOF
}

cmd="${1:-}"; shift || true
case "$cmd" in
  vm-create)
    preflight
    if vm_exists; then log "VM '$VM' already exists"; else
      log "cloning $IMAGE -> $VM (first pull can take many minutes)"
      tart clone "$IMAGE" "$VM"
    fi
    ;;

  vm-up)
    preflight
    vm_exists || { log "VM '$VM' does not exist — creating"; "$0" vm-create; }
    if vm_running && [ -n "$(vm_ip)" ]; then log "VM '$VM' already up at $(vm_ip)"; echo "$(vm_ip)"; exit 0; fi
    tart set "$VM" --cpu "$CPU" --memory "$MEMORY" --display "$DISPLAY_SIZE"
    # Unlock the host login.keychain for macOS guests (see KEYCHAIN_PW note above).
    if [ -n "$KEYCHAIN_PW" ]; then
      if security unlock-keychain -p "$KEYCHAIN_PW" login.keychain 2>/dev/null; then
        log "host login.keychain unlocked (required for macOS guests on macOS 15+)"
      else
        log "WARN: could not unlock login.keychain — a macOS guest may fail with a Code=-9 security error"
      fi
    fi
    RUN_ARGS=(run "$VM" --no-graphics)
    [ -n "$SHARE" ] && RUN_ARGS+=(--dir="$SHARE")
    # mount the shared host cache read-only (if it exists) so the guest can reuse
    # cached IDE binaries instead of downloading its own copy
    [ -d "$CACHE_DIR" ] && RUN_ARGS+=(--dir="$CACHE_TAG:$CACHE_DIR:ro")
    log "booting '$VM' detached (--no-graphics, full GUI session inside): tart ${RUN_ARGS[*]}"
    # Detach hard: nohup ignores SIGHUP, </dev/null + >log frees the SSH channel,
    # `disown` drops it from this shell's job table. The VM then outlives the
    # agent's SSH connection — this is the "keep the VM alive" management piece.
    nohup tart "${RUN_ARGS[@]}" </dev/null >>"$RUN_LOG" 2>&1 &
    disown || true
    for i in $(seq 1 90); do [ -n "$(vm_ip)" ] && break; sleep 2; done
    ip="$(vm_ip)"; [ -n "$ip" ] || die "VM got no IP after 180s — see $RUN_LOG"
    log "VM up at $ip"
    echo "$ip"
    ;;

  vm-ip) vm_ip; ;;

  vm-status)
    preflight
    echo "vm=$VM"
    echo "exists=$(vm_exists && echo yes || echo no)"
    echo "running=$(vm_running && echo yes || echo no)"
    echo "ip=$(vm_ip)"
    if [ -n "$(vm_ip)" ]; then
      echo "provisioned=$(gssh 'test -f ~/.tart-skills-provisioned && echo yes || echo no' 2>/dev/null || echo unknown)"
    fi
    ;;

  vm-down) preflight; log "stopping $VM"; tart stop "$VM" 2>/dev/null || true; rm -f "$MUX"; ;;
  vm-gc)   preflight; log "deleting $VM"; tart stop "$VM" 2>/dev/null || true; tart delete "$VM" 2>/dev/null || true; rm -f "$MUX"; ;;

  provision)
    preflight
    SRC=""
    SELFDIR="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)"
    for c in "${TART_PROVISION:-}" "$SELFDIR/provision/provision.sh" \
             "$HOME/tart-skills/provision/provision.sh" "$HOME/provision/provision.sh"; do
      [ -n "$c" ] && [ -f "$c" ] && { SRC="$c"; break; }
    done
    [ -n "$SRC" ] || die "provision.sh not found (set TART_PROVISION, or place it at ~/tart-skills/provision/provision.sh)"
    log "copying + running provision.sh in guest (installs take a while)"
    gscp "$SRC" ":/tmp/provision.sh"
    gssh 'bash /tmp/provision.sh'
    ;;

  guest)
    if [ "$#" -eq 0 ]; then gssh; else gssh "$@"; fi
    ;;

  screenshot)
    OUT="${1:--}"
    R="/tmp/tart-shot-$$.png"
    gssh "screencapture -x '$R'"
    if [ "$OUT" = "-" ]; then
      gssh "cat '$R'"; gssh "rm -f '$R'"
    else
      [ "${OUT#/}" = "$OUT" ] && OUT="$ART_DIR/$OUT"   # relative -> artifacts dir
      gscp ":$R" "$OUT"; gssh "rm -f '$R'"
      log "screenshot saved: $OUT"; echo "$OUT"
    fi
    ;;

  record)
    SECS="${1:?usage: record SECS [OUT]}"; OUT="${2:--}"
    R="/tmp/tart-vid-$$.mov"
    # caffeinate keeps display+idle+system awake so the capture never freezes
    # on a display sleep (byte-identical-frames bug from the source repo).
    gssh "caffeinate -d -i -s -t $((SECS+5)) >/dev/null 2>&1 & disown; screencapture -V $SECS -v '$R' >/tmp/tart-sc.log 2>&1; echo exit=\$?" >&2
    if [ "$OUT" = "-" ]; then
      gssh "cat '$R'"; gssh "rm -f '$R'"
    else
      [ "${OUT#/}" = "$OUT" ] && OUT="$ART_DIR/$OUT"
      gscp ":$R" "$OUT"; gssh "rm -f '$R'"
      log "video saved: $OUT"; echo "$OUT"
    fi
    ;;

  start-ide)
    PROJECT="${1:-}"
    # `open -a` routes through launchd into the user's Aqua GUI session, so the
    # IDE gets a real desktop context (an SSH-forked java dies HeadlessException).
    # Prefer the shared host cache (mounted read-only) over a per-VM install.
    APP="$(gssh "for d in \"$GUEST_CACHE/ide\" /Applications; do ls -d \"\$d\"/IntelliJ*.app 2>/dev/null; done | head -1")"
    [ -n "$APP" ] || die "IntelliJ not found (shared cache or /Applications) — run: tart-remote cache-setup and/or provision"
    if [ -n "$PROJECT" ]; then
      log "opening IntelliJ with project: $PROJECT"
      gssh "open -a '$APP' '$PROJECT'"
    else
      log "launching IntelliJ: $APP"
      gssh "open -a '$APP'"
    fi
    log "IntelliJ launched; give it time to index (poll the screen with 'screenshot')"
    ;;

  click) X="${1:?x}"; Y="${2:?y}"; gssh "cliclick m:$X,$Y c:$X,$Y"; ;;
  type)  T="${1:?text}"; gssh "cliclick t:'$T'"; ;;
  key)   K="${1:?keystroke}"; gssh "cliclick kp:'$K' 2>/dev/null || cliclick t:'$K'"; ;;

  pull)  gscp "$1" "$2"; ;;

  vm-list|ls)
    # show ALL tart VMs on this shared host so you can pick a free name and see
    # which VMs belong to other tasks — never stop/delete a VM you did not create
    preflight; tart list
    ;;

  cache-setup)
    # Populate the shared host cache with the IntelliJ IDEA CE app ONCE, on the
    # host. Every VM then mounts it read-only (vm-up) and runs the IDE from
    # there — no per-VM download, no per-VM copy. Runs on macOS (hdiutil/curl are
    # stock; no Homebrew needed).
    mkdir -p "$CACHE_DIR/ide"
    if ls -d "$CACHE_DIR"/ide/IntelliJ*.app >/dev/null 2>&1; then
      log "IDE already cached: $(ls -d "$CACHE_DIR"/ide/IntelliJ*.app | head -1)"
    else
      URL="${TART_IDE_URL:-https://download.jetbrains.com/product?code=IIC&latest&distribution=macM1}"
      log "downloading IntelliJ IDEA CE into shared cache (once): $URL"
      curl -fL "$URL" -o /tmp/tart-idea.dmg
      MNT="$(mktemp -d)"
      hdiutil attach -nobrowse -quiet -mountpoint "$MNT" /tmp/tart-idea.dmg
      cp -R "$MNT"/*.app "$CACHE_DIR/ide/" 2>/dev/null || { hdiutil detach -quiet "$MNT"; die "no .app in the downloaded dmg"; }
      hdiutil detach -quiet "$MNT"; rm -f /tmp/tart-idea.dmg
      xattr -dr com.apple.quarantine "$CACHE_DIR"/ide/*.app 2>/dev/null || true
      log "cached: $(ls -d "$CACHE_DIR"/ide/IntelliJ*.app | head -1)"
    fi
    du -sh "$CACHE_DIR" 2>/dev/null | awk '{print "cache size: "$1}'
    ;;

  cache-status)
    echo "cache_dir=$CACHE_DIR"
    if [ -d "$CACHE_DIR" ]; then
      echo "exists=yes size=$(du -sh "$CACHE_DIR" 2>/dev/null | awk '{print $1}')"
      echo "ide=$(ls -d "$CACHE_DIR"/ide/IntelliJ*.app 2>/dev/null | head -1 || echo none)"
    else
      echo "exists=no (run: tart-remote cache-setup)"
    fi
    ;;

  ""|-h|--help|help) usage; ;;
  *) log "unknown subcommand: $cmd"; usage; exit 1; ;;
esac
